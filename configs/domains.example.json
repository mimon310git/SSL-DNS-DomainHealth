{
  "version": 1,
  "defaults": {
    "timeout_seconds": 8,
    "ssl_warning_days": 21,
    "ssl_critical_days": 7,
    "user_agent": "DomainSentinel/0.1",
    "follow_redirects_for_http": true,
    "max_redirect_hops": 5,
    "verify_tls": true
  },
  "sites": [
    {
      "id": "example-main",
      "domain": "example.com",
      "url": "https://example.com/",
      "checks": ["ssl", "dns", "redirect", "http"],
      "expect": {
        "status_code": 200,
        "body_contains": "Example Domain"
      }
    },
    {
      "id": "github-home",
      "domain": "github.com",
      "url": "https://github.com/",
      "checks": ["ssl", "dns", "redirect", "http"],
      "expect": {
        "status_code": 200
      }
    },
    {
      "id": "python-home",
      "domain": "www.python.org",
      "url": "https://www.python.org/",
      "checks": ["ssl", "dns", "redirect", "http"],
      "expect": {
        "status_code": 200,
        "body_contains": "Python"
      }
    },
    {
      "id": "iana-dns",
      "domain": "iana.org",
      "checks": ["dns"]
    },
    {
      "id": "globalsqa-demo",
      "domain": "www.globalsqa.com",
      "url": "https://www.globalsqa.com/demo-site/",
      "checks": ["ssl", "dns", "redirect", "http"]
    }
  ]
}
